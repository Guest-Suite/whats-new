NOTION_API_KEY=       # Token de l'intégration Notion "API Produit" (requis)
ANTHROPIC_API_KEY=    # Clé API Anthropic pour la génération de contenu (requis)
GENERATE_SECRET=      # Secret Bearer pour protéger POST /api/generate (partagé avec n8n)
SLACK_WEBHOOK_URL=    # Incoming Webhook Slack pour notifier après génération
DATA_DIR=             # REQUIS EN PRODUCTION. Chemin vers le dossier persistant (ex: /var/data/whats-new). En dev, fallback sur server/data/
